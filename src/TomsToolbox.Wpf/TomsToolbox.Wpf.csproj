<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\TargetFrameworks.Desktop.props" />
  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <UseWpf>true</UseWpf>
  </PropertyGroup>
  <PropertyGroup>
    <Title>Tom's Toolbox WPF Module</Title>
  </PropertyGroup>
  <ItemGroup Condition="'$(TargetFrameworkIdentifier)'=='.NETFramework'">
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.ComponentModel.DataAnnotations" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Nullable.cs" Link="Nullable.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\TomsToolbox.Essentials\TomsToolbox.Essentials.csproj" />
    <ProjectReference Include="..\TomsToolbox.ObservableCollections\TomsToolbox.ObservableCollections.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" />
    <PackageReference Include="Fody" PrivateAssets="All" />
    <PackageReference Include="JetBrains.Annotations" PrivateAssets="All" />
    <PackageReference Include="JetBrainsAnnotations.Fody" PrivateAssets="All" />
    <PackageReference Include="Throttle.Fody" PrivateAssets="All" />
    <PackageReference Include="WeakEventHandler.Fody" PrivateAssets="All" />
  </ItemGroup>
</Project>